# Server port (default: 3001)
PORT=3001

# Default working directory for commands
DEFAULT_CWD=/home/ubuntu

# Directory to look for QR code images (optional)
QR_DIR=/home/ubuntu/Downloads

# Directory for file serving (default: ./files)
FILES_DIR=./files

# Command execution timeout in ms (default: 60000)
TIMEOUT_MS=60000

# Max stdout/stderr buffer in bytes (default: 10MB)
MAX_BUFFER=10485760
